# JARVIS FASE 5 - Environment Variables Template
# Copia este archivo a .env y completa con tus valores

# ============================================================================
# SISTEMA
# ============================================================================
JARVIS_ENV=production
JARVIS_DEBUG=false
JARVIS_LOG_LEVEL=INFO

# ============================================================================
# TAILSCALE
# ============================================================================
TAILSCALE_API_KEY=your_tailscale_api_key_here
TAILSCALE_AUTH_KEY=your_tailscale_auth_key_here

# ============================================================================
# OPENAI / GPT
# ============================================================================
OPENAI_API_KEY=sk-your_openai_api_key_here

# ============================================================================
# GITHUB
# ============================================================================
GITHUB_API_KEY=ghp_your_github_token_here
GITHUB_USERNAME=your_github_username

# ============================================================================
# SPOTIFY
# ============================================================================
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret

# ============================================================================
# SLACK
# ============================================================================
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# ============================================================================
# WEATHER API
# ============================================================================
WEATHER_API_KEY=your_weather_api_key_here

# ============================================================================
# GOOGLE MAPS
# ============================================================================
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# ============================================================================
# TWILIO (SMS)
# ============================================================================
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# ============================================================================
# EMAIL CONFIGURATION
# ============================================================================
EMAIL_ADDRESS=your_email@gmail.com
EMAIL_PASSWORD=your_app_specific_password
ADMIN_EMAIL=admin@example.com

# ============================================================================
# DATABASE
# ============================================================================
DATABASE_URL=sqlite:///jarvis.db
DATABASE_BACKUP_PATH=/backups/jarvis

# ============================================================================
# SECURITY
# ============================================================================
JWT_SECRET=your_jwt_secret_key_here_min_32_chars
ENCRYPTION_KEY=your_encryption_key_here

# ============================================================================
# SERVER
# ============================================================================
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
SERVER_WORKERS=4

# ============================================================================
# LOGGING
# ============================================================================
LOG_FILE=logs/jarvis.log
LOG_MAX_SIZE_MB=100
LOG_RETENTION_DAYS=30

# ============================================================================
# BACKUP
# ============================================================================
BACKUP_ENABLED=true
BACKUP_INTERVAL_HOURS=24
BACKUP_LOCATION=/backups/jarvis
BACKUP_RETENTION_DAYS=30

# ============================================================================
# DEVELOPMENT
# ============================================================================
DEV_MODE=false
MOCK_EXTERNAL_APIS=false
PROFILING_ENABLED=false
